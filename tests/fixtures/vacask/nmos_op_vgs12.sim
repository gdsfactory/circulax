// Single NMOS DC op-point at Vds=0.6, Vgs=1.2 (strong inversion).

ground 0

load "psp103v4.osdi"
include "models.inc"
model vsource vsource

m1   (d g 0 0)  nmos w=10u l=1u
vds  (d 0)      vsource dc=0.6
vgs  (g 0)      vsource dc=1.2

control
  options rawfile="binary" strictsave=1
  analysis op1 op
endc
